{
  "manifest_version": 3,
  "name": "Easy Chrome",
  "version": "1.0",
  "description": "Simple Chrome extension for common browser actions.",
  "permissions": [
    "tabs",
    "storage",
    "activeTab",
    "tabGroups",
    "browsingData",
    "tabCapture",
    "scripting"
  ],
  "action": {
    "default_popup": "src/html/popup.html",
    "default_icon": {
      "128": "public/icons/icon.svg"
    }
  },
  "background": {
    "service_worker": "src/js/background/screenshot.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/js/content/hideContent.js"]
    }
  ],
  "icons": {
    "128": "public/icons/icon.svg"
  }
} 